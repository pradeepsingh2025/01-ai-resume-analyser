// User → has many ResumeTexts
// User → has many JobDescriptions
// User → has many Analyses
// User → has many Rewrites
// Each Analysis belongs to one User, one JobDescription, and one ResumeText
// Each Rewrite belongs to one User and one Analysis

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())

  resumes         ResumeText[]
  jobDescriptions JobDescription[]
  analyses        Analysis[]
  rewrites        Rewrite[]
}

model JobDescription {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  analyses Analysis[]
}

model ResumeText {
  id            String   @id @default(cuid())
  content       String
  embeddedLinks String[]
  createdAt     DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  analyses Analysis[]
}

model Analysis {
  id              String   @id @default(cuid())
  atsScore        Int
  missingKeywords String[]
  strengths       String[]
  weaknesses      String[]
  overallFeedback String
  createdAt       DateTime @default(now())

  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobDescriptionId String
  jobDescription   JobDescription @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)

  resumeTextId     String
  resumeText       ResumeText     @relation(fields: [resumeTextId], references: [id], onDelete: Cascade)

  rewrites         Rewrite[]
}

// ── Rewrite (top-level) ─────────────────────────────────────────────
model Rewrite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Fields from rewriteSchema
  name             String            // Full name
  summary          String?           // 2-4 sentence professional summary
  achievements     String[]          // Awards, rankings, recognitions
  changesExplained String[]          // List of changes made and why

  // Relations — parent
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  // Relations — children
  contact    RewriteContact?
  skills     RewriteSkill[]
  experience RewriteExperience[]
  education  RewriteEducation[]
  projects   RewriteProject[]
}

// ── Contact info ────────────────────────────────────────────────────
model RewriteContact {
  id        String  @id @default(cuid())
  email     String?
  phone     String?
  linkedin  String?
  github    String?
  location  String?
  website   String?

  rewriteId String  @unique
  rewrite   Rewrite @relation(fields: [rewriteId], references: [id], onDelete: Cascade)
}

// ── Skills ──────────────────────────────────────────────────────────
model RewriteSkill {
  id    String   @id @default(cuid())
  label String             // e.g. "Languages", "Frameworks"
  items String[]           // 5-10 items per category

  rewriteId String
  rewrite   Rewrite @relation(fields: [rewriteId], references: [id], onDelete: Cascade)
}

// ── Experience ──────────────────────────────────────────────────────
model RewriteExperience {
  id       String   @id @default(cuid())
  company  String
  location String?
  title    String
  duration String            // e.g. "Jan 2023 – Present"
  bullets  String[]          // 2-6 action-driven bullet points

  rewriteId String
  rewrite   Rewrite @relation(fields: [rewriteId], references: [id], onDelete: Cascade)
}

// ── Education ───────────────────────────────────────────────────────
model RewriteEducation {
  id          String  @id @default(cuid())
  institution String
  degree      String
  duration    String
  gpa         String?
  coursework  String?

  rewriteId String
  rewrite   Rewrite @relation(fields: [rewriteId], references: [id], onDelete: Cascade)
}

// ── Projects ────────────────────────────────────────────────────────
model RewriteProject {
  id        String   @id @default(cuid())
  name      String
  date      String?
  techStack String[]          // Technologies used
  bullets   String[]          // 2-5 action-driven bullet points
  link      String?           // GitHub / live demo URL

  rewriteId String
  rewrite   Rewrite @relation(fields: [rewriteId], references: [id], onDelete: Cascade)
}
